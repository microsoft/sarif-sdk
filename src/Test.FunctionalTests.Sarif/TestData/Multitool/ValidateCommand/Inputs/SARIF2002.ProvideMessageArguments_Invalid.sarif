{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "version": "1.2.3",
          "rules": [
            {
              "id": "TEST1001",
              "messageStrings": {
                "default": {
                  "text": "'{0}'."
                }
              }
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "TEST1001",
          "message": {
            "text": "Test message."
          }
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}