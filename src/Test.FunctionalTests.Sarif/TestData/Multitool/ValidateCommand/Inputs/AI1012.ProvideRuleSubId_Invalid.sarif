{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "version": "1.2.3",
          "rules": [
            {
              "id": "CWE-862",
              "name": "PlanEventMissingAuthorization"
            }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CWE-862",
          "ruleIndex": 0,
          "message": { "text": "Bare CWE base id with a resolvable descriptor; the missing sub-id can be appended and the kebab suggestion derives from rule.name." }
        },
        {
          "ruleId": "CWE-77",
          "message": { "text": "Bare CWE base id with no resolvable descriptor; the kebab suggestion falls back to 'readable-slug'." }
        },
        {
          "ruleId": "TST0002",
          "message": { "text": "Non-CWE, non-NOVEL base; no appended sub-id can make it conform." }
        },
        {
          "ruleId": "CWE-89/KQL_Injection",
          "message": { "text": "Sub-id is not lowercase kebab-case (uppercase plus underscore)." }
        },
        {
          "ruleId": "NOVEL/prompt-injection",
          "message": { "text": "NOVEL escape hatch must be flat 'NOVEL-<sub-id>'; the slash form is malformed." }
        },
        {
          "ruleId": "CWE-89/",
          "message": { "text": "Empty sub-id after the slash." }
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}
