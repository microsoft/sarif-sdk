{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.6.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "version": "1.2.3",
          "rules": [
            {
              "id": "TEST001",
              "name": "TestRule"
            }
          ]
        }
      },
      "artifacts": [
        {
          "location": { "uri": "src/foo.cs" },
          "parentIndex": -1
        }
      ],
      "results": [
        {
          "ruleId": "TEST001",
          "ruleIndex": -1,
          "message": { "text": "ruleIndex literally emits the -1 sentinel \u2014 fires." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "src/foo.cs",
                  "index": -1
                },
                "region": { "startLine": 42 }
              }
            }
          ]
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}
