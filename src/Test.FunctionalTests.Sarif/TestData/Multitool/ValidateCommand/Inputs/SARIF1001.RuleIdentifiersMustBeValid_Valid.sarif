{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "CodeScanner",
          "version": "1.0",
          "rules": [
            {
              "id": "RULE0001",
              "name": "Rule one"
            },
            {
              "id": "RULE0002",
              "name": "Rule two"
            }
          ]
        }
      },
      "results": [],
      "columnKind": "utf16CodeUnits"
    },
    {
      "tool": {
        "driver": {
          "name": "AIAnalyzer",
          "version": "1.0",
          "notifications": [
            {
              "id": "DECISION",
              "name": "Decision"
            },
            {
              "id": "RULE-COVERAGE-GAP",
              "name": "RuleCoverageGap"
            }
          ]
        }
      },
      "results": [],
      "properties": {
        "ai/origin": "test-fixture"
      },
      "columnKind": "utf16CodeUnits"
    }
  ]
}
