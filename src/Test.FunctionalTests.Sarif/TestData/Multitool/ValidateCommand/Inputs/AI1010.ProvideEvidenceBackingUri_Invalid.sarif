{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "version": "1.2.3",
          "rules": [
            { "id": "CWE-78", "name": "OsCommandInjection" }
          ]
        }
      },
      "results": [
        {
          "ruleId": "CWE-78/api-handler",
          "ruleIndex": 0,
          "message": { "text": "Array-form backing where each non-resolving sarif URI should produce its own AI1010 finding." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/foo.cs" },
                "region": { "startLine": 1 }
              }
            }
          ],
          "properties": {
            "ai/evidence": [
              {
                "summary": "Single-string backing pointing at an out-of-range result index.",
                "strength": "demonstrated",
                "backing": "sarif:/runs/0/results/99/locations/0"
              },
              {
                "summary": "Array form where one element is a non-resolving sarif URI; this is the form the prior code crashed on (issue #2908).",
                "strength": "demonstrated",
                "backing": [
                  "https://example.com/external.md",
                  "sarif:/runs/0/results/0/locations/99",
                  "sarif:/runs/42/results/0"
                ]
              }
            ]
          }
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}
