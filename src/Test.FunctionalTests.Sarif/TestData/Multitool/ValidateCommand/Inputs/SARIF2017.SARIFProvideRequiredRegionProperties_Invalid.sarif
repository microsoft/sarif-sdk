{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "version": "1.2.3",
          "rules": [
            { "id": "TEST001", "name": "TestRule" }
          ]
        }
      },
      "results": [
        {
          "ruleId": "TEST001",
          "ruleIndex": 0,
          "message": { "text": "physicalLocation with no 'region' at all \u2014 fires MissingRegion." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/a.cs" }
              }
            }
          ]
        },
        {
          "ruleId": "TEST001",
          "ruleIndex": 0,
          "message": { "text": "physicalLocation with an empty 'region: {}' \u2014 fires MissingRegionProperty (no positional info in any of the three valid forms)." },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "src/b.cs" },
                "region": {}
              }
            }
          ]
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}
