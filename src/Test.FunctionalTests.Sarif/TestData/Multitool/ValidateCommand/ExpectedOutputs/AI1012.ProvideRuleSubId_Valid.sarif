{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "rules": [
            {
              "id": "AI1012",
              "name": "ProvideRuleSubId",
              "fullDescription": {
                "text": "AI-generated results must carry a hierarchical sub-component on 'result.ruleId' beyond the base 'reportingDescriptor.id'. SARIF has no 'result.name'; the hierarchical 'ruleId' is the one slot where a per-finding readable handle survives minimal SARIF, and it is the suppression and baseline grouping key (SARIF spec §3.27.5). Choose a true sub-classification of the base rule when one applies (e.g. 'CWE-78/api-handler'); otherwise kebab-case the rule's friendly 'name'. Choose granularity deliberately: results that should be dispositioned as a bundle share a sub-ID; distinct issues under one base rule get distinct sub-IDs."
              },
              "messageStrings": {
                "Error_Missing": {
                  "text": "{0}: 'result.ruleId' is '{1}' with no sub-component beyond the descriptor id. Append a hierarchical sub-ID: a true sub-classification of '{1}' if one applies, otherwise the kebab-cased rule name (e.g. '{1}/{2}'). SARIF has no 'result.name'; this sub-ID is that name and the bulk-disposition key (§3.27.5)."
                },
                "Error_DescriptorIdContainsSlash": {
                  "text": "{0}: 'reportingDescriptor.id' is '{1}' and contains a '/' sub-component. The SARIF specification permits descriptor identifiers to be opaque strings (§3.49.3 — descriptor.id is declared as \"a string\", not a hierarchical string), but the AI profile additionally requires descriptor identifiers to be slash-free base IDs ('CWE-78', not 'CWE-78/api-handler') so that every AI-generated result can reliably extend the base via 'result.ruleId' with its own sub-component (§3.27.5, §3.52.4 — one additional hierarchical component beyond descriptor.id). This keeps the rule entry in 'tool.driver.rules' stable across results and reserves the hierarchical sub-component slot for the per-finding handle. Move the sub-component off the descriptor and onto each result that needs it."
                }
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "http://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "FunctionalTestOutput.ValidateCommand/AI1012.ProvideRuleSubId_Valid.sarif",
            "uriBaseId": "TEST_DIR"
          }
        }
      ],
      "results": [
        {
          "ruleId": "AI1012",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "id": "Error_Missing",
            "arguments": [
              "runs[0].results[2]",
              "CWE-78/api-handler",
              "api-handler-command-injection"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "index": 0
                },
                "region": {
                  "startLine": 37,
                  "startColumn": 9
                }
              }
            }
          ]
        },
        {
          "ruleId": "AI1012",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "id": "Error_DescriptorIdContainsSlash",
            "arguments": [
              "runs[0].tool.driver.rules[2].id",
              "CWE-78/api-handler"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "index": 0
                },
                "region": {
                  "startLine": 20,
                  "startColumn": 40
                }
              }
            }
          ]
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}