{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0-rtm.6.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "rules": [
            {
              "id": "SARIF2017",
              "name": "SARIFProvideRequiredRegionProperties",
              "fullDescription": {
                "text": "Results should localize their physical locations with a non-empty 'region' object. SARIF §3.30 defines three valid region representations: line/column-based ('startLine'/'startColumn'/'endLine'/'endColumn'); character-offset-based ('charOffset'/'charLength'); or byte-offset-based ('byteOffset'/'byteLength'). Any one form localizes the finding, but producers SHOULD fully express both start AND end positions — consumers (IDEs highlighting precise spans, diff tools rendering inline annotations, downstream agents) rely on column data, not the spec's permissive defaults ('startColumn' defaults to 1, 'endLine' defaults to 'startLine', 'endColumn' defaults to end-of-line). The SDK helper 'FileRegionsCache.PopulateTextRegionProperties' fills in derived properties ('endLine', 'endColumn', char/byte offsets, and 'snippet') from a minimal starting region. Sibling rules SARIF2010 ('ProvideCodeSnippets') and SARIF2011 ('ProvideContextRegion') ask for additional region content for a complete result. For findings that apply to a whole artifact, the minimum forms suffice: '{ startLine: 1, endLine: <lineCount> }' (line-based, stable under newline normalization); '{ charOffset: 0, charLength: <chars> }' (when the content is in hand as a string); or '{ byteOffset: 0, byteLength: <bytes> }' (universal; required for binary artifacts)."
              },
              "messageStrings": {
                "Warning_MissingRegion": {
                  "text": "{0}: The 'region' property is absent. Express the location via a 'region' object in one of the SARIF §3.30 forms: line/column ('startLine'/'startColumn'/'endLine'/'endColumn'); char-offset ('charOffset'/'charLength'); or byte-offset ('byteOffset'/'byteLength'). Fully express both start AND end positions — consumers rely on column data, not the spec's permissive defaults. See also SARIF2010 ('region.snippet') and SARIF2011 ('contextRegion') for a complete result. For a whole-artifact finding, the minimum suffices: '{ startLine: 1, endLine: <lineCount> }', '{ charOffset: 0, charLength: <chars> }', or '{ byteOffset: 0, byteLength: <bytes> }'."
                },
                "Warning_MissingRegionProperty": {
                  "text": "{0}: The 'region' object carries no positional information. Populate one of the SARIF §3.30 forms: line/column ('startLine'/'startColumn'/'endLine'/'endColumn'); char-offset ('charOffset'/'charLength'); or byte-offset ('byteOffset'/'byteLength'). Fully express both start AND end positions — consumers rely on column data, not the spec's permissive defaults. See also SARIF2010 ('region.snippet') and SARIF2011 ('contextRegion') for a complete result. For a whole-artifact finding, the minimum suffices: '{ startLine: 1, endLine: <lineCount> }', '{ charOffset: 0, charLength: <chars> }', or '{ byteOffset: 0, byteLength: <bytes> }'."
                }
              },
              "helpUri": "http://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "FunctionalTestOutput.ValidateCommand/SARIF2017.SARIFProvideRequiredRegionProperties_Invalid.sarif",
            "uriBaseId": "TEST_DIR"
          }
        }
      ],
      "results": [
        {
          "ruleId": "SARIF2017",
          "ruleIndex": 0,
          "message": {
            "id": "Warning_MissingRegion",
            "arguments": [
              "runs[0].results[0].locations[0].physicalLocation"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "index": 0
                },
                "region": {
                  "startLine": 22,
                  "startColumn": 35
                }
              }
            }
          ]
        },
        {
          "ruleId": "SARIF2017",
          "ruleIndex": 0,
          "message": {
            "id": "Warning_MissingRegionProperty",
            "arguments": [
              "runs[0].results[1].locations[0].physicalLocation.region"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "index": 0
                },
                "region": {
                  "startLine": 36,
                  "startColumn": 27
                }
              }
            }
          ]
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}