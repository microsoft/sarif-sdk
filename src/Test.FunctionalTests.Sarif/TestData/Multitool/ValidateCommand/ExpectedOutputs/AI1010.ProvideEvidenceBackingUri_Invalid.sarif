{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "rules": [
            {
              "id": "AI1010",
              "name": "ProvideEvidenceBackingUri",
              "fullDescription": {
                "text": "Every 'sarif:' URI in 'ai/evidence[].backing' SHALL resolve to an element within the containing log file per SARIF spec §3.10.3."
              },
              "messageStrings": {
                "Error_Default": {
                  "text": "{0}: The 'ai/evidence' entry at index {1} has a 'backing' value of '{2}' which uses the 'sarif:' URI scheme but does not resolve to a valid element in the log file."
                }
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "http://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "FunctionalTestOutput.ValidateCommand/AI1010.ProvideEvidenceBackingUri_Invalid.sarif",
            "uriBaseId": "TEST_DIR"
          }
        }
      ],
      "results": [
