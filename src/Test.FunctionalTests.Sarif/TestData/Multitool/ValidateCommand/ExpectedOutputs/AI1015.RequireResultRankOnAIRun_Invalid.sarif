{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "rules": [
            {
              "id": "AI1015",
              "name": "RequireResultRankOnAIRun",
              "fullDescription": {
                "text": "When a run declares 'ai/origin' on 'run.properties' (i.e., this is an AI-emitted run), every 'result' MUST carry 'result.rank'. Confidence is first-class on AI findings: it drives triage priority and downstream filtering. Without 'rank' the consumer has no signal of how strongly the producer believes in the result. This rule does not fire on non-AI runs; the SARIF-general recommendation in AI2010 covers those at note severity."
              },
              "messageStrings": {
                "Error_Default": {
                  "text": "{0}: This result is missing 'rank'. The run declares 'ai/origin', so every result MUST express confidence as a numeric rank (0.0 to 100.0) per the AI profile."
                }
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "http://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
      "artifacts": [
        {
          "location": {
            "uri": "FunctionalTestOutput.ValidateCommand/AI1015.RequireResultRankOnAIRun_Invalid.sarif",
            "uriBaseId": "TEST_DIR"
          }
        }
      ],
      "results": [
        {
          "ruleId": "AI1015",
          "ruleIndex": 0,
          "level": "error",
          "message": {
            "id": "Error_Default",
            "arguments": [
              "runs[0].results[1]"
            ]
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "index": 0
                },
                "region": {
                  "startLine": 28,
                  "startColumn": 9
                }
              }
            }
          ]
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}