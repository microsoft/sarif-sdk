{
  "$schema": "https://schemastore.azurewebsites.net/schemas/json/sarif-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SARIF Functional Testing",
          "rules": [
            {
              "id": "AI1012",
              "name": "ProvideRuleSubId",
              "fullDescription": {
                "text": "AI-generated results must carry a hierarchical sub-component on 'result.ruleId' beyond the base 'reportingDescriptor.id'. SARIF has no 'result.name'; the hierarchical 'ruleId' is the one slot where a per-finding readable handle survives minimal SARIF, and it is the suppression and baseline grouping key (SARIF spec §3.27.5). The accepted shapes are a taxonomy sub-ID, 'CWE-<number>/<sub-id>' (e.g. 'CWE-78/api-handler'), or the escape hatch 'NOVEL-<sub-id>' for a finding that maps to no taxonomy entry; the sub-ID is lowercase kebab-case and the 'NOVEL-' form takes no slash. This is the same convention the 'emit' verb hard-enforces, so logs produced by other paths conform too. Choose a true sub-classification of the base rule when one applies; otherwise kebab-case the rule's friendly 'name'. Choose granularity deliberately: results that should be dispositioned as a bundle share a sub-ID; distinct issues under one base rule get distinct sub-IDs."
              },
              "messageStrings": {
                "Error_Missing": {
                  "text": "{0}: 'result.ruleId' is '{1}' with no sub-component beyond the descriptor id. Append a hierarchical sub-ID: a true sub-classification of '{1}' if one applies, otherwise the kebab-cased rule name (e.g. '{1}/{2}'). SARIF has no 'result.name'; this sub-ID is that name and the bulk-disposition key (§3.27.5)."
                },
                "Error_Malformed": {
                  "text": "{0}: 'result.ruleId' is '{1}', which does not match the AI ruleId convention. Use a taxonomy sub-ID 'CWE-<number>/<sub-id>' (e.g. 'CWE-89/kql-injection') or the escape hatch 'NOVEL-<sub-id>' (e.g. 'NOVEL-prompt-injection'); the sub-ID is lowercase kebab-case and the 'NOVEL-' form takes no slash. No appended sub-ID can repair this value, so rewrite it to a conformant shape (§3.27.5)."
                }
              },
              "defaultConfiguration": {
                "level": "error"
              },
              "helpUri": "http://docs.oasis-open.org/sarif/sarif/v2.1.0/sarif-v2.1.0.html"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
