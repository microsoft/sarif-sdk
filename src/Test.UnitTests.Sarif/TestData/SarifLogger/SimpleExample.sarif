{
  "$schema": "https://docs.oasis-open.org/sarif/sarif/v2.1.0/errata01/os/schemas/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "SarifLoggerTests",
          "rules": [
            {
              "id": "MyId"
            }
          ]
        }
      },
      "invocations": [
        {
          "executionSuccessful": true
        }
      ],
      "results": [
        {
          "ruleId": "MyId",
          "ruleIndex": 0,
          "message": {
            "text": "My text"
          }
        }
      ],
      "columnKind": "utf16CodeUnits"
    }
  ]
}