              }
            },
            {
              "id": "CWE-705",
              "name": "IncorrectControlFlowScoping",
              "shortDescription": {
                "text": "The product does not properly return control flow to the proper location after it has completed a task or detected an unusual condition."
              },
              "help": {
                "text": "The product does not properly return control flow to the proper location after it has completed a task or detected an unusual condition.",
                "markdown": "## Description\n\nThe product does not properly return control flow to the proper location after it has completed a task or detected an unusual condition.\n\n## Common Consequences\n\n- **Scope**: Other. **Impact**: Alter Execution Logic, Other."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/705.html",
              "properties": {
                "cwe/title": "Incorrect Control Flow Scoping",
                "cwe/status": "Incomplete",
                "cwe/abstraction": "Class",
