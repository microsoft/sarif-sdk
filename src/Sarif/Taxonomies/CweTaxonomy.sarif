              }
            },
            {
              "id": "CWE-706",
              "name": "UseOfIncorrectlyResolvedNameOrReference",
              "shortDescription": {
                "text": "The product uses a name or reference to access a resource, but the name/reference resolves to a resource that is outside of the intended control sphere."
              },
              "help": {
                "text": "The product uses a name or reference to access a resource, but the name/reference resolves to a resource that is outside of the intended control sphere.",
                "markdown": "## Description\n\nThe product uses a name or reference to access a resource, but the name/reference resolves to a resource that is outside of the intended control sphere.\n\n## Common Consequences\n\n- **Scope**: Confidentiality, Integrity. **Impact**: Read Application Data, Modify Application Data."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/706.html",
              "properties": {
                "cwe/title": "Use of Incorrectly-Resolved Name or Reference",
                "cwe/status": "Incomplete",
