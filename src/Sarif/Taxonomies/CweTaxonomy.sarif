              }
            },
            {
              "id": "CWE-704",
              "name": "IncorrectTypeConversionOrCast",
              "shortDescription": {
                "text": "The product does not correctly convert an object, resource, or structure from one type to a different type."
              },
              "help": {
                "text": "The product does not correctly convert an object, resource, or structure from one type to a different type.",
                "markdown": "## Description\n\nThe product does not correctly convert an object, resource, or structure from one type to a different type.\n\n## Common Consequences\n\n- **Scope**: Other. **Impact**: Other."
              },
              "helpUri": "https://cwe.mitre.org/data/definitions/704.html",
              "properties": {
                "cwe/title": "Incorrect Type Conversion or Cast",
                "cwe/status": "Incomplete",
