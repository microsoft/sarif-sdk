{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/microsoft/sarif-sdk/main/src/Sarif.Multitool.Library/GetSchema/ai-run-header.schema.json",
  "title": "SARIF AI emit profile \u2014 run header object",
  "description": "Input contract for the SARIF run-header partial document an AI producer supplies to the emit-init-run verb. An overlay on the canonical SARIF 2.1.0 run: it reuses the base shape by $ref and tightens it for the AI profile, requiring the run-scoped fields the profile mandates and bouncing header fields the replayer ignores.",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://json.schemastore.org/sarif-2.1.0.json#/definitions/run"
    }
  ],
  "required": [
    "tool",
    "versionControlProvenance",
    "properties"
  ],
  "properties": {
    "tool": {
      "type": "object",
      "required": [
        "driver"
      ],
      "properties": {
        "driver": {
          "type": "object",
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "description": "Non-empty, non-whitespace tool driver name.",
              "type": "string",
              "minLength": 1,
              "pattern": "\\S"
            },
            "informationUri": {
              "description": "When present, a canonical lowercase https URI.",
              "type": "string",
              "pattern": "^https://"
            }
          }
        }
      }
    },
    "versionControlProvenance": {
      "description": "At least one version-control provenance entry. Each repositoryUri, when present, is a canonical lowercase https URI.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "repositoryUri": {
            "type": "string",
            "pattern": "^https://"
          }
        }
      }
    },
    "originalUriBaseIds": {
      "type": "object",
      "properties": {
        "SRCROOT": {
          "type": "object",
          "properties": {
            "uri": {
              "description": "Canonical lowercase https or file URI.",
              "type": "string",
              "pattern": "^(https|file)://"
            }
          }
        }
      }
    },
    "automationDetails": {
      "type": "object",
      "properties": {
        "guid": {
          "description": "Canonical 8-4-4-4-12 hex GUID.",
          "type": "string",
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        },
        "correlationGuid": {
          "description": "Canonical 8-4-4-4-12 hex GUID.",
          "type": "string",
          "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}$"
        }
      }
    },
    "properties": {
      "description": "ai/origin is required and identifies how the run was produced.",
      "type": "object",
      "required": [
        "ai/origin"
      ],
      "properties": {
        "ai/origin": {
          "enum": [
            "generated",
            "annotated",
            "synthesized"
          ]
        }
      }
    },
    "results": false,
    "invocations": false
  }
}
