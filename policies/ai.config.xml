<?xml version="1.0" encoding="utf-8"?>
<Properties>
  <!-- Enable GH1003 (disabled by default) and fire at error level for AI validation.
       AI-generated findings must provide region data with at least startLine. -->
  <Properties Key='GH1003.ProvideRequiredRegionProperties.Options'>
    <Property Key='RuleEnabled' Value='Error' />
  </Properties>
  <!-- Elevate SARIF2010 from note to warning for AI validation.
       AI-generated findings should provide code snippets for self-contained results. -->
  <Properties Key='SARIF2010.ProvideCodeSnippets.Options'>
    <Property Key='RuleEnabled' Value='Warning' />
  </Properties>
  <!-- Elevate SARIF2011 from note to warning for AI validation.
       AI-generated findings should provide context regions for surrounding code. -->
  <Properties Key='SARIF2011.ProvideContextRegion.Options'>
    <Property Key='RuleEnabled' Value='Warning' />
  </Properties>
</Properties>
